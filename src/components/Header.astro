---
const categories = [
  { name: 'Electronice', slug: 'electronice-gadgeturi' },
  { name: 'IT & Laptopuri', slug: 'it-laptopuri' },
  { name: 'Electrocasnice', slug: 'electrocasnice-mari' },
  { name: 'Bucatarie', slug: 'electrocasnice-mici-premium' },
  { name: 'Mobila', slug: 'mobila-home-living' },
  { name: 'Sport', slug: 'sport-fitness' }
];

const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="container-main">
    <nav class="header-nav">
      <!-- Logo -->
      <a href="/" class="header-logo">
        <div class="header-logo-icon">
          <span>B</span>
        </div>
        <span class="header-logo-text">Balador<span class="gold">.ro</span></span>
      </a>

      <!-- Desktop Navigation -->
      <div class="nav-desktop">
        <a href="/" class:list={["nav-link", { "active": currentPath === "/" }]}>
          Acasa
        </a>
        {categories.map(cat => (
          <a
            href={`/${cat.slug}/`}
            class:list={["nav-link", { "active": currentPath.includes(cat.slug) }]}
          >
            {cat.name}
          </a>
        ))}
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="mobile-menu-btn"
        aria-label="Deschide meniul"
        aria-expanded="false"
      >
        <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </nav>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="nav-mobile">
      <a href="/" class:list={["nav-link", { "active": currentPath === "/" }]}>
        Acasa
      </a>
      {categories.map(cat => (
        <a
          href={`/${cat.slug}/`}
          class:list={["nav-link", { "active": currentPath.includes(cat.slug) }]}
        >
          {cat.name}
        </a>
      ))}
    </div>
  </div>
</header>

<style>
  .header {
    background: linear-gradient(to bottom, var(--color-primary-950) 0%, var(--color-primary-900) 100%);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 8px -2px rgb(0 0 0 / 0.3);
  }

  .header-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 0;
    gap: 16px;
  }

  .header-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .header-logo-icon {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, var(--color-accent-400) 0%, var(--color-accent-600) 100%);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px -2px rgba(251, 191, 36, 0.5);
    transition: transform 0.2s;
  }

  .header-logo:hover .header-logo-icon {
    transform: scale(1.05);
  }

  .header-logo-icon span {
    color: var(--color-primary-950);
    font-weight: 800;
    font-size: 20px;
  }

  .header-logo-text {
    color: white;
    font-weight: 700;
    font-size: 20px;
    display: none;
  }

  @media (min-width: 480px) {
    .header-logo-text {
      display: block;
    }
  }

  .header-logo-text .gold {
    color: var(--color-accent-400);
  }

  /* Desktop Navigation */
  .nav-desktop {
    display: none;
    align-items: center;
    gap: 4px;
  }

  @media (min-width: 1024px) {
    .nav-desktop {
      display: flex;
    }
  }

  .nav-link {
    color: var(--color-primary-200);
    font-size: 14px;
    font-weight: 500;
    padding: 10px 14px;
    border-radius: 8px;
    transition: all 0.2s;
    text-decoration: none;
    display: block;
  }

  .nav-link:hover {
    color: white;
    background: rgba(255, 255, 255, 0.1);
  }

  .nav-link.active {
    color: var(--color-accent-400);
    background: rgba(251, 191, 36, 0.12);
  }

  /* Mobile Menu Button */
  .mobile-menu-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    color: white;
    cursor: pointer;
    border-radius: 8px;
    transition: background 0.2s;
  }

  .mobile-menu-btn:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  @media (min-width: 1024px) {
    .mobile-menu-btn {
      display: none;
    }
  }

  .mobile-menu-btn svg {
    width: 24px;
    height: 24px;
  }

  .mobile-menu-btn .close-icon {
    display: none;
  }

  .mobile-menu-btn.active .menu-icon {
    display: none;
  }

  .mobile-menu-btn.active .close-icon {
    display: block;
  }

  /* Mobile Navigation */
  .nav-mobile {
    display: none;
    flex-direction: column;
    padding-bottom: 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin-top: 8px;
  }

  .nav-mobile.open {
    display: flex;
  }

  @media (min-width: 1024px) {
    .nav-mobile {
      display: none !important;
    }
  }

  .nav-mobile .nav-link {
    padding: 14px 0;
    font-size: 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .nav-mobile .nav-link:last-child {
    border-bottom: none;
  }
</style>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('open');
    menuBtn?.classList.toggle('active');
    menuBtn?.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  });
</script>
